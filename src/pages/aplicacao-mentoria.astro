---
/**
 * LP de Aplicação para a mentoria (issue 64 — protótipo).
 * Página fina: o formulário multi-etapas (logo + cartão + validação +
 * envio ao /tracker com redirect decidido pelo backend) vive no componente
 * compartilhado AplicacaoForm (extraído nesta issue 70). Sem o campo de
 * investimento — comportamento observável idêntico ao anterior.
 * O BaseLayout já cuida do tracking padrão (GA4 + Meta Pixel + espelho
 * POST /tracker com captura de UTMs) — nenhum mecanismo novo aqui.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import AplicacaoForm from '../components/AplicacaoForm.astro';
---

<BaseLayout
  title="Aplicação para a Mentoria | Atacado Exponencial"
  description="Aplique para a sua sessão estratégica gratuita: nosso time analisa o seu negócio de atacado e entra em contato pelo WhatsApp."
  showHeader={false}
  showFooter={false}
>
  <AplicacaoForm funnel="aplicacao-mentoria" />
</BaseLayout>
