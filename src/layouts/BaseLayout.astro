---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  showHeader?: boolean;
  showFooter?: boolean;
}

const {
  title,
  description = 'Atacado Exponencial — método para marcas de atacado venderem mais.',
  showHeader = true,
  showFooter = true,
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <!-- Pré-carrega a fonte da primeira dobra para reduzir o LCP -->
    <link rel="preload" href="/fonts/Satoshi-Bold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Satoshi-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <!-- GA4 (gtag) via proxy first-party /scripts (anti-adblock). Envia só o
         PageView no client; conversões (Lead/Purchase) continuam server-side no
         /tracker — sem contagem dupla. Measurement ID não é secreto. -->
    <script async is:inline src="/scripts/gtag.js?id=G-3C24BQVR59"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-3C24BQVR59');
    </script>
    <!-- Meta Pixel via proxy first-party /scripts (anti-adblock). PageView
         redundante: cópia do navegador (fbq) + espelho server-side no /tracker
         com o mesmo event_id — o Meta deduplica e conta 1. Pixel ID não é secreto. -->
    <script is:inline>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      '/scripts/fbevents.js');
      fbq('init', '915637492681788');
      // Pixel 2 — conta de anúncios nova (migração). fbq('track') dispara para
      // todos os pixels inicializados; mesmo event_id → dedup por pixel no Meta.
      fbq('init', '2800317883678788');
      // event_id único por visualização — mesmo padrão dos pontos de Lead
      var pvEventId = 'pv-' + Date.now() + '-' + Math.random().toString(36).slice(2, 8);
      // Cópia do navegador (deduplicada no Meta pelo event_id)
      fbq('track', 'PageView', {}, { eventID: pvEventId });
      // Espelho server-side — via autoritativa; fire-and-forget, falha silenciosa
      fetch('/tracker', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          event_name: 'PageView',
          event_id: pvEventId,
          event_time: Math.floor(Date.now() / 1000),
          event_source_url: window.location.href,
        }),
      }).catch(function () { /* silencioso */ });
    </script>
  </head>
  <body>
    {showHeader && <Header />}
    <slot />
    {showFooter && <Footer />}
  </body>
</html>
