---
import { Image } from 'astro:assets';
import logo from '../assets/brand/logo.png';
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" aria-label="Atacado Exponencial — início">
      <Image src={logo} alt="Atacado Exponencial" height={72} class="site-header__logo" />
    </a>
  </div>
</header>

<style>
  .site-header {
    padding-block: 1.25rem;
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .site-header__logo {
    height: 2.25rem;
    width: auto;
  }
</style>
