---
const testimonials = [
  { initials: 'MR', name: 'M. Ribeiro', role: 'Marca de moda feminina · São Paulo', quote: 'Aplicamos o plano e em 3 meses dobramos nossa base de revendedores ativos. O diagnóstico mostrou exatamente onde estávamos errando na captação.' },
  { initials: 'AL', name: 'A. Lima', role: 'Atacado de acessórios · Rio de Janeiro', quote: 'Finalmente entendi por que minha recompra era tão baixa. Parecia simples depois que o Felipe mostrou, mas a gente fica tão dentro do dia a dia que não enxerga.' },
  { initials: 'CS', name: 'C. Souza', role: 'Marca infantil atacado · Minas Gerais', quote: 'Não foi uma consultoria genérica. Cada ponto foi analisado dentro da realidade do meu negócio. Saí com um plano concreto, não com teoria.' },
];
---

<section class="section section--light testi">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Resultados</span>
      <h2 class="section-title">Marcas que <span class="testi__hl">aplicaram</span> o método e escalaram com resultados</h2>
      <p class="section-sub">+100 marcas atendidas</p>
    </div>
    <div class="testi__track">
      {testimonials.map((t) => (
        <figure class="testi__card">
          <div class="testi__stars" aria-label="5 estrelas">★★★★★</div>
          <blockquote class="testi__quote">{t.quote}</blockquote>
          <figcaption class="testi__author">
            <span class="testi__avatar">{t.initials}</span>
            <span>
              <strong class="testi__name">{t.name}</strong>
              <span class="testi__role">{t.role}</span>
            </span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .testi__hl { color: rgba(30, 30, 30, 0.55); }
  .testi__track {
    margin-top: 3rem;
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 85%;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-bottom: 1rem;
    -webkit-overflow-scrolling: touch;
  }
  .testi__card {
    scroll-snap-align: center;
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid rgba(30, 30, 30, 0.1);
    border-radius: 1rem;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 0;
  }
  .testi__stars { color: #e0a106; letter-spacing: 0.1em; }
  .testi__quote { font-size: 0.95rem; line-height: 1.6; color: rgba(30, 30, 30, 0.85); }
  .testi__author { display: flex; align-items: center; gap: 0.75rem; }
  .testi__avatar {
    width: 2.5rem; height: 2.5rem; border-radius: 9999px;
    background: #1e1e1e; color: #fff;
    display: inline-flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 0.8rem; flex-shrink: 0;
  }
  .testi__name { display: block; font-size: 0.9rem; }
  .testi__role { display: block; font-size: 0.75rem; color: rgba(30, 30, 30, 0.6); }
  @media (min-width: 768px) {
    .testi__track { grid-auto-flow: row; grid-template-columns: repeat(3, 1fr); grid-auto-columns: auto; overflow: visible; }
  }
</style>
