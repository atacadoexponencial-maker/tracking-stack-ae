---
// Seção Resultados com depoimentos em VÍDEO (Panda Video) — mesmo molde
// visual da Testimonials.astro (texto), usada hoje só na /trafego-atacado.
// Os vídeos são verticais (9:16); loading="lazy" evita carregar os players no load.
interface Props {
  title: string;
  sub?: string;
  videos: { name: string; videoId: string }[];
}
const { title, sub = '', videos = [] } = Astro.props;

// Library do Panda Video da marca (vz-718ea161-967, conforme o código de
// incorporação oficial do painel).
const PANDA_EMBED = 'https://player-vz-718ea161-967.tv.pandavideo.com.br/embed/?v=';
---

<section class="section section--light vtesti">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Resultados</span>
      <h2 class="section-title">{title}</h2>
      {sub && <p class="section-sub">{sub}</p>}
    </div>
    <div class="vtesti__track">
      {videos.map((v) => (
        <div class="vtesti__card">
          <div class="vtesti__frame">
            <iframe
              src={`${PANDA_EMBED}${v.videoId}`}
              title={`Depoimento de ${v.name}`}
              loading="lazy"
              allow="accelerometer; gyroscope; autoplay; encrypted-media; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .vtesti__track {
    margin-top: 3rem;
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 70%;
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding-bottom: 1rem;
    -webkit-overflow-scrolling: touch;
  }
  .vtesti__card {
    scroll-snap-align: center;
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid rgba(30, 30, 30, 0.1);
    border-radius: 1rem;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    margin: 0;
  }
  .vtesti__frame {
    aspect-ratio: 9 / 16;
    border-radius: 0.625rem;
    overflow: hidden;
    background: #1e1e1e;
  }
  .vtesti__frame iframe { width: 100%; height: 100%; border: 0; display: block; }
  @media (min-width: 768px) {
    .vtesti__track { grid-auto-flow: row; grid-template-columns: repeat(4, 1fr); grid-auto-columns: auto; overflow: visible; }
  }
</style>
