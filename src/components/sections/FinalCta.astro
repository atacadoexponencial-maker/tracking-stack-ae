---
interface Props {
  id?: string;
  title?: string;
  sub?: string;
  ctaLabel?: string;
  ctaHref?: string;
  notes?: string[];
}
const {
  id,
  title = 'Você já tem o potencial. Agora precisa do plano.',
  sub,
  ctaLabel = 'Agendar diagnóstico gratuito',
  ctaHref,
  notes,
} = Astro.props;
---

<section class="section final" id={id}>
  <div class="container final__inner">
    <span class="eyebrow">Próximo passo</span>
    <h2 class="final__title">{title}</h2>
    {sub ? (
      <p class="final__sub">{sub}</p>
    ) : (
      <p class="final__sub">
        35 minutos. Individual. Gratuito. E com um plano de ação personalizado para sair da sessão já sabendo o que fazer.
      </p>
    )}
    {ctaHref ? (
      <a class="btn-cta final__cta" href={ctaHref}>
        {ctaLabel} <span aria-hidden="true">→</span>
      </a>
    ) : (
      <button type="button" class="btn-cta final__cta" data-open-chat>
        Agendar diagnóstico gratuito <span aria-hidden="true">→</span>
      </button>
    )}
    {notes ? (
      <div class="final__notes">
        {notes.map((n) => <span>{n}</span>)}
      </div>
    ) : (
      <div class="final__notes">
        <span>100% gratuito · sem cartão</span>
        <span>Vagas limitadas por semana</span>
      </div>
    )}
  </div>
</section>

<style>
  .final { padding-block: 5rem; }
  .final__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
    max-width: 40rem;
    margin-inline: auto;
  }
  .final__title { font-size: clamp(1.75rem, 4.5vw, 3rem); }
  .final__sub { color: hsl(var(--muted-foreground)); font-size: 1.05rem; }
  .final__cta { margin-top: 0.5rem; }
  .final__notes {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
    color: hsl(var(--muted-foreground));
    font-size: 0.8rem;
  }
</style>
