---
/**
 * Chat conversacional nativo de captação de lead (issue 14, island leve).
 * Recria o fluxo do Typebot de diagnóstico dentro do próprio domínio, para
 * preservar o tracking first-party. Ao concluir, envia o lead ao backend
 * (/tracker, event "Lead") que registra a atribuição, dispara o Meta CAPI,
 * encaminha ao CRM e devolve o destino (WhatsApp/Calendly) conforme o
 * faturamento — o chat apenas redireciona para o destino retornado.
 *
 * UX inspirada no Typebot: mensagens chegam uma a uma com indicador de
 * "digitando…", avatar do host e transições suaves.
 *
 * Abre ao clicar em qualquer elemento com [data-open-chat].
 */
import { getImage } from 'astro:assets';
import logo from '../assets/brand/sem-fundo-branco.png';
import felipeImg from '../assets/brand/felipe.webp';

const avatar = await getImage({ src: felipeImg, width: 96, height: 96 });

// Funil declarado pela página que usa o chat. A home passa 'sessao-estrategica';
// as demais (ex.: /vsl) herdam o padrão 'diagnostico'. Vai como first-touch no
// /tracker quando a URL não traz um &funnel= próprio.
// `fullPage`: modo página dedicada (estilo Typebot) — abre sozinho no load, em
// tela cheia e sem botão de fechar. Default false preserva o modal da home.
const { funnel = 'diagnostico', fullPage = false } = Astro.props;
---

<div id="lead-chat" class:list={['lead-chat', { 'lead-chat--full': fullPage }]} hidden aria-hidden="true" data-avatar={avatar.src} data-funnel={funnel} data-full-page={fullPage} role="dialog" aria-modal="true" aria-label="Inscrição na consultoria">
  <div class="lead-chat__panel">
    <header class="lead-chat__header">
      <span class="lead-chat__id">
        <img src={avatar.src} alt="" class="lead-chat__id-avatar" width="32" height="32" />
        <span class="lead-chat__id-text">
          <strong>Atacado Exponencial</strong>
          <span class="lead-chat__id-status">online agora</span>
        </span>
      </span>
      <button type="button" class="lead-chat__close" data-close-chat aria-label="Fechar">&times;</button>
    </header>
    <div class="lead-chat__messages" id="lead-chat-messages"></div>
    <div class="lead-chat__input" id="lead-chat-input"></div>
  </div>
</div>

<style is:global>
  .lead-chat {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.78);
    padding: 1rem;
    backdrop-filter: blur(2px);
  }
  .lead-chat[hidden] { display: none; }
  /* Modo página dedicada: sem botão de fechar (não faz sentido numa página que É o form). */
  .lead-chat--full .lead-chat__close { display: none; }
  .lead-chat__panel {
    width: 100%;
    max-width: 30rem;
    height: min(92vh, 42rem);
    background: #141414;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1.25rem;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.45);
    animation: lc-pop 0.3s cubic-bezier(0.2, 0.9, 0.3, 1.2);
  }
  @keyframes lc-pop { from { opacity: 0; transform: translateY(16px) scale(0.98); } to { opacity: 1; transform: none; } }
  .lead-chat__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1.1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    background: #1a1a1a;
  }
  .lead-chat__id { display: flex; align-items: center; gap: 0.6rem; }
  .lead-chat__id-avatar { width: 2rem; height: 2rem; border-radius: 9999px; object-fit: cover; }
  .lead-chat__id-text { display: flex; flex-direction: column; line-height: 1.2; }
  .lead-chat__id-text strong { font-size: 0.85rem; color: #fff; }
  .lead-chat__id-status { font-size: 0.7rem; color: #4ade80; display: flex; align-items: center; gap: 0.3rem; }
  .lead-chat__id-status::before { content: ''; width: 0.4rem; height: 0.4rem; border-radius: 9999px; background: #4ade80; }
  .lead-chat__close { background: none; border: none; color: rgba(255, 255, 255, 0.5); font-size: 1.5rem; line-height: 1; }
  .lead-chat__close:hover { color: #fff; }

  .lead-chat__messages {
    flex: 1;
    overflow-y: auto;
    padding: 1.25rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .lead-chat__row { display: flex; align-items: flex-end; gap: 0.5rem; max-width: 100%; }
  .lead-chat__row--user { justify-content: flex-end; }
  .lead-chat__avatar { width: 1.6rem; height: 1.6rem; border-radius: 9999px; object-fit: cover; flex-shrink: 0; }
  .lead-chat__avatar--spacer { visibility: hidden; }
  .lead-chat__bubble {
    background: #262626;
    color: #f3f3f3;
    padding: 0.7rem 0.95rem;
    border-radius: 1.1rem;
    border-bottom-left-radius: 0.3rem;
    max-width: 78%;
    font-size: 0.92rem;
    line-height: 1.5;
    animation: lc-in 0.28s ease;
  }
  .lead-chat__row--user .lead-chat__bubble {
    background: #fff;
    color: #1e1e1e;
    border-bottom-left-radius: 1.1rem;
    border-bottom-right-radius: 0.3rem;
    font-weight: 600;
  }
  @keyframes lc-in { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }
  .lead-chat__typing { display: inline-flex; gap: 0.22rem; padding: 0.9rem 1rem; }
  .lead-chat__typing span {
    width: 0.42rem; height: 0.42rem; border-radius: 9999px; background: rgba(255, 255, 255, 0.5);
    animation: lc-bounce 1.1s infinite ease-in-out;
  }
  .lead-chat__typing span:nth-child(2) { animation-delay: 0.18s; }
  .lead-chat__typing span:nth-child(3) { animation-delay: 0.36s; }
  @keyframes lc-bounce { 0%, 60%, 100% { transform: translateY(0); opacity: 0.5; } 30% { transform: translateY(-0.3rem); opacity: 1; } }

  .lead-chat__input {
    padding: 0.9rem 1rem 1.1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-height: 0;
  }
  .lead-chat__input input {
    width: 100%;
    background: #0a0a0a;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 0.8rem;
    color: #fff;
    padding: 0.85rem 1rem;
    font-family: inherit;
    font-size: 0.92rem;
  }
  .lead-chat__input input::placeholder { color: rgba(255, 255, 255, 0.3); }
  .lead-chat__input input:focus { outline: none; border-color: rgba(255, 255, 255, 0.55); }
  .lead-chat__btn {
    background: #fff;
    color: #1e1e1e;
    border: none;
    border-radius: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
    padding: 0.9rem 1rem;
    transition: opacity 0.15s ease;
  }
  .lead-chat__btn:hover { opacity: 0.9; }
  .lead-chat__btn:disabled { opacity: 0.5; }
  .lead-chat__choices { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; max-height: 14rem; overflow-y: auto; }
  .lead-chat__choice {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 0.7rem;
    color: rgba(255, 255, 255, 0.88);
    padding: 0.7rem 0.5rem;
    font-size: 0.78rem;
    text-align: center;
    transition: all 0.15s ease;
  }
  .lead-chat__choice:hover { border-color: #fff; background: rgba(255, 255, 255, 0.08); }
  .lead-chat__error { color: #f87171; font-size: 0.75rem; }
</style>

<script>
  import { telefoneValido, TELEFONE_ERRO, aplicarMascaraTelefone, sugerirEmail } from '../scripts/lead-validacao';

  type Step =
    | { kind: 'messages'; texts: string[] }
    | { kind: 'start'; button: string }
    | { kind: 'input'; key: string; inputType: 'text' | 'tel' | 'email'; before?: string[]; question: string; placeholder: string; validate: (v: string) => boolean; errorMsg: string }
    | { kind: 'choice'; key: string; before?: string[]; question: string; options: string[] };

  const FAT_OPTIONS = [
    'Menos de 20 Mil', 'De 20 a 30 Mil', 'De 30 a 40 Mil', 'De 40 a 75 Mil',
    'De 75 a 100 Mil', 'De 100 a 150 Mil', 'De 150 a 200 Mil', 'De 200 a 300 Mil',
    'De 300 a 500 Mil', 'Mais de 500 Mil',
  ];

  const STEPS: Step[] = [
    { kind: 'messages', texts: [
      'Bem-vindo à inscrição da consultoria individual e gratuita do Atacado Exponencial. 👋',
      'Estamos muito felizes pelo seu interesse, mas lembre-se: o preenchimento não garante vaga 🚨 Esse é um trabalho bem cuidadoso e personalizado, então não é possível de ser feito com todos os interessados.',
      'Preencha com bastante atenção algumas perguntas bem rápidas 👇🏼',
    ] },
    { kind: 'start', button: 'Toque para começar' },
    { kind: 'input', key: 'nome', inputType: 'text', question: 'Qual o seu nome?', placeholder: 'Digite seu nome', validate: (v) => v.trim().length >= 2, errorMsg: 'Digite seu nome.' },
    { kind: 'input', key: 'telefone', inputType: 'tel', before: ['Importante: para que eu consiga entrar em contato pra te avisar sobre sua aprovação.'], question: 'Qual o seu Whatsapp?', placeholder: 'Digite seu Whatsapp', validate: telefoneValido, errorMsg: TELEFONE_ERRO },
    { kind: 'input', key: 'email', inputType: 'email', before: ['(Só lembrando que vou mandar o link da sessão por lá)'], question: 'Qual o seu melhor email?', placeholder: 'Digite seu email', validate: (v) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim()), errorMsg: 'Digite um email válido.' },
    { kind: 'input', key: 'instagram', inputType: 'text', question: 'Excelente! Qual o @instagram da sua marca?', placeholder: 'Digite o @ do Instagram', validate: (v) => v.trim().length >= 1, errorMsg: 'Digite o @ da sua marca.' },
    { kind: 'choice', key: 'faturamento', before: ['Show!'], question: 'qual o faturamento MENSAL do seu negócio?', options: FAT_OPTIONS },
    { kind: 'input', key: 'justificativa', inputType: 'text', question: 'Qual o principal desafio do seu negócio hoje?', placeholder: 'Conte em poucas palavras', validate: (v) => v.trim().length >= 2, errorMsg: 'Conta um pouquinho pra gente.' },
    { kind: 'input', key: 'objetivo', inputType: 'text', question: 'E qual o seu maior objetivo para os próximos meses?', placeholder: 'Conte em poucas palavras', validate: (v) => v.trim().length >= 2, errorMsg: 'Conta um pouquinho pra gente.' },
  ];

  const overlay = document.getElementById('lead-chat') as HTMLElement | null;
  const messagesEl = document.getElementById('lead-chat-messages') as HTMLElement | null;
  const inputEl = document.getElementById('lead-chat-input') as HTMLElement | null;

  if (overlay && messagesEl && inputEl) {
    const avatarUrl = overlay.dataset.avatar || '';
    const leadFunnel = overlay.dataset.funnel || 'diagnostico';
    const fullPage = overlay.dataset.fullPage === 'true';
    const answers: Record<string, string> = {};
    let stepIndex = 0;
    let started = false;
    let lastSender: 'bot' | 'user' | null = null;

    const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));
    const scrollDown = () => { messagesEl.scrollTop = messagesEl.scrollHeight; };

    function addUserBubble(text: string) {
      const row = document.createElement('div');
      row.className = 'lead-chat__row lead-chat__row--user';
      const b = document.createElement('div');
      b.className = 'lead-chat__bubble';
      b.textContent = text;
      row.appendChild(b);
      messagesEl!.appendChild(row);
      lastSender = 'user';
      scrollDown();
    }

    function addBotBubble(text: string) {
      const row = document.createElement('div');
      row.className = 'lead-chat__row';
      const av = document.createElement('img');
      av.className = 'lead-chat__avatar' + (lastSender === 'bot' ? ' lead-chat__avatar--spacer' : '');
      av.src = avatarUrl;
      av.alt = '';
      const b = document.createElement('div');
      b.className = 'lead-chat__bubble';
      b.textContent = text;
      row.appendChild(av);
      row.appendChild(b);
      messagesEl!.appendChild(row);
      lastSender = 'bot';
      scrollDown();
    }

    async function botSay(text: string) {
      // indicador "digitando…"
      const typingRow = document.createElement('div');
      typingRow.className = 'lead-chat__row';
      const av = document.createElement('img');
      av.className = 'lead-chat__avatar' + (lastSender === 'bot' ? ' lead-chat__avatar--spacer' : '');
      av.src = avatarUrl;
      av.alt = '';
      const typing = document.createElement('div');
      typing.className = 'lead-chat__bubble lead-chat__typing';
      typing.innerHTML = '<span></span><span></span><span></span>';
      typingRow.appendChild(av);
      typingRow.appendChild(typing);
      messagesEl!.appendChild(typingRow);
      scrollDown();
      await sleep(Math.min(1400, 500 + text.length * 16));
      typingRow.remove();
      addBotBubble(text);
    }

    function clearInput() { inputEl!.innerHTML = ''; }

    function open() {
      overlay!.hidden = false;
      overlay!.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      if (!started) { started = true; stepIndex = 0; renderStep(); }
    }
    function close() {
      overlay!.hidden = true;
      overlay!.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    async function renderStep() {
      clearInput();
      if (stepIndex >= STEPS.length) { submit(); return; }
      const step = STEPS[stepIndex];

      if (step.kind === 'messages') {
        for (const t of step.texts) { await botSay(t); }
        stepIndex++;
        renderStep();
        return;
      }
      if (step.kind === 'start') {
        const btn = document.createElement('button');
        btn.className = 'lead-chat__btn';
        btn.textContent = step.button;
        btn.onclick = () => { addUserBubble(step.button); stepIndex++; renderStep(); };
        inputEl!.appendChild(btn);
        return;
      }
      if (step.kind === 'input') {
        for (const t of (step.before || [])) { await botSay(t); }
        await botSay(step.question);
        const input = document.createElement('input');
        input.type = step.inputType;
        input.placeholder = step.placeholder;
        if (step.inputType === 'tel') aplicarMascaraTelefone(input);
        const err = document.createElement('p');
        err.className = 'lead-chat__error';
        err.hidden = true;
        const btn = document.createElement('button');
        btn.className = 'lead-chat__btn';
        btn.textContent = 'Enviar';
        let emailSuspeito = '';
        const advance = () => {
          const v = input.value.trim();
          if (!step.validate(v)) { err.textContent = step.errorMsg; err.hidden = false; return; }
          // Typo de domínio (ex.: ghotmail.com): pede confirmação UMA vez;
          // enviar de novo o mesmo valor confirma — nunca bloqueia de vez.
          if (step.key === 'email') {
            const sug = sugerirEmail(v);
            if (sug && v !== emailSuspeito) {
              emailSuspeito = v;
              err.textContent = `Será que não é ${sug}? Confira — ou toque Enviar de novo para confirmar.`;
              err.hidden = false;
              return;
            }
          }
          answers[step.key] = v;
          addUserBubble(v);
          stepIndex++;
          renderStep();
        };
        btn.onclick = advance;
        input.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); advance(); } });
        inputEl!.appendChild(input);
        inputEl!.appendChild(err);
        inputEl!.appendChild(btn);
        input.focus();
        return;
      }
      if (step.kind === 'choice') {
        for (const t of (step.before || [])) { await botSay(t); }
        const nome = answers['nome'] ? answers['nome'].split(' ')[0] + ', ' : '';
        await botSay(nome + step.question);
        const grid = document.createElement('div');
        grid.className = 'lead-chat__choices';
        step.options.forEach((opt) => {
          const c = document.createElement('button');
          c.className = 'lead-chat__choice';
          c.textContent = opt;
          c.onclick = () => { answers[step.key] = opt; addUserBubble(opt); stepIndex++; renderStep(); };
          grid.appendChild(c);
        });
        inputEl!.appendChild(grid);
        return;
      }
    }

    async function submit() {
      await botSay('Parabéns! Você foi selecionado(a) para falar com nossos especialistas do Atacado Exponencial. Estamos muito felizes pelo seu interesse! 🎉');
      await botSay('Estamos te direcionando agora…');
      let redirect = '';
      const eventId = 'lead-' + Date.now() + '-' + Math.random().toString(36).slice(2, 8);
      try { if (typeof (window as any).fbq === 'function') (window as any).fbq('track', 'Lead', {}, { eventID: eventId }); } catch (e) { /* espelho browser nunca bloqueia o envio */ }
      try {
        const res = await fetch('/tracker', {
          method: 'POST',
          // keepalive: o navegador termina o envio mesmo se a aba fechar no
          // meio (comum no browser embutido do Instagram) — sem isso o fbq
          // acima conta o lead no Meta e o /tracker nunca recebe nada.
          keepalive: true,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            event_name: 'Lead',
            event_id: eventId,
            event_time: Math.floor(Date.now() / 1000),
            event_source_url: window.location.href,
            user_data: { em: answers['email'], ph: answers['telefone'], fn: answers['nome'] },
            lead_data: {
              nome: answers['nome'], telefone: answers['telefone'], email: answers['email'],
              instagram: answers['instagram'], faturamento: answers['faturamento'],
              justificativa: answers['justificativa'], objetivo: answers['objetivo'],
              funnel: leadFunnel,
            },
          }),
        });
        const data = await res.json();
        redirect = data && data.redirect ? data.redirect : '';
      } catch (e) {
        /* mesmo sem resposta, segue para o destino padrão abaixo */
      }
      if (redirect) {
        window.location.href = redirect;
      } else {
        await botSay('Clique no botão abaixo para falar com nossos especialistas 👇🏼');
      }
    }

    document.querySelectorAll('[data-open-chat]').forEach((el) => {
      el.addEventListener('click', (e) => { e.preventDefault(); open(); });
    });
    overlay.querySelectorAll('[data-close-chat]').forEach((el) => {
      el.addEventListener('click', close);
    });
    // No modo página dedicada não fecha ao clicar no fundo; e abre sozinho no load.
    if (!fullPage) {
      overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });
    }
    if (fullPage) { open(); }
  }
</script>
